{
  "name": "clinica-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @clinica/web dev",
    "dev:api": "pnpm --filter @clinica/api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @clinica/web build",
    "build:api": "pnpm --filter @clinica/api build",
    "start": "pnpm --filter @clinica/web start",
    "start:web": "pnpm --filter @clinica/web start",
    "start:api": "pnpm --filter @clinica/api start",
    "db:generate": "pnpm --filter @clinica/database db:generate",
    "db:migrate": "pnpm --filter @clinica/database db:migrate",
    "db:migrate:status": "pnpm --filter @clinica/database db:migrate:status",
    "db:migrate:deploy": "pnpm --filter @clinica/database db:migrate:deploy",
    "db:migrate:reset": "pnpm --filter @clinica/database db:migrate:reset",
    "db:validate": "pnpm --filter @clinica/database db:validate",
    "db:seed": "pnpm --filter @clinica/database db:seed",
    "db:studio": "pnpm --filter @clinica/database db:studio",
    "lint": "pnpm -r lint",
    "structure": "echo '📂 Frontend: apps/web/src/' && ls apps/web/src && echo '' && echo '⚙️  Backend: apps/api/src/' && ls apps/api/src && echo '' && echo '📦 Packages:' && ls packages"
  },
  "devDependencies": {
    "@types/node": "^20",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5"
  }
}
