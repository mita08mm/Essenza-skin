datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  rol       Rol
  nombre    String
  apellido  String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultas      Consulta[]
  prescripciones Prescripcion[]

  @@index([email])
  @@map("usuarios")
}

enum Rol {
  ADMIN
  MEDICO
  RECEPCIONISTA
}

model Paciente {
  id              String                 @id @default(uuid())
  nombre          String
  apellido        String
  documento       String
  tipoDocumento   TipoDocumentoIdentidad
  fechaNacimiento DateTime
  telefono        String
  email           String?
  direccion       String?
  sexo            String?

  objetivoEstetico   String?
  alergias           String?
  condicionesMedicas String?
  medicacionActual   String?
  embarazoLactancia  Boolean? @default(false)

  contactoEmergenciaNombre   String?
  contactoEmergenciaTelefono String?
  estado                     EstadoPaciente @default(ACTIVO)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  historiaClinica HistoriaClinica?
  citas           Cita[]
  cobros          Cobro[]
  consultas       Consulta[]
  prescripciones  Prescripcion[]
  documentos      Documento[]

  @@unique([documento, tipoDocumento])
  @@index([nombre, apellido])
  @@index([documento])
  @@index([estado])
  @@map("pacientes")
}

enum TipoDocumentoIdentidad {
  CI
  PASAPORTE
}

enum EstadoPaciente {
  ACTIVO
  INACTIVO
}

model HistoriaClinica {
  id         String @id @default(uuid())
  pacienteId String @unique

  tipoSangre              String?
  diagnosticoPrincipal    String?
  alergias                String?
  medicacionHabitual      String?
  antecedentesPersonales  String?
  antecedentesFamiliares  String?
  antecedentesQuirurgicos String?
  notasGenerales          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paciente  Paciente   @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  consultas Consulta[]

  @@index([pacienteId])
  @@map("historias_clinicas")
}

model Consulta {
  id                String   @id @default(uuid())
  pacienteId        String
  historiaClinicaId String
  usuarioId         String
  citaId            String?
  fecha             DateTime @default(now())

  tipoTratamiento   TipoTratamiento // Facial, Corporal, Capilar
  nombreTratamiento String // Nombre específico del procedimiento
  zonaTratada       String // Área específica del cuerpo
  objetivo          String // Objetivo del tratamiento

  // Evaluación y protocolo
  evaluacionInicial String? // Estado inicial de la piel/área
  protocolo         String? // Protocolo aplicado
  observaciones     String?
  proximaSesion     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  historiaClinica HistoriaClinica @relation(fields: [historiaClinicaId], references: [id], onDelete: Cascade)
  paciente        Paciente        @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  usuario         Usuario         @relation(fields: [usuarioId], references: [id])
  cita            Cita?           @relation(fields: [citaId], references: [id])
  prescripciones  Prescripcion[]
  cobros          Cobro[]

  @@index([pacienteId])
  @@index([historiaClinicaId])
  @@index([fecha])
  @@index([citaId])
  @@index([tipoTratamiento])
  @@map("consultas")
}

enum TipoTratamiento {
  FACIAL
  CORPORAL
  CAPILAR
  COMBINADO
}

model Cita {
  id              String           @id @default(uuid())
  pacienteId      String
  fecha           DateTime
  horaInicio      String
  horaFin         String
  tipoTratamiento TipoTratamiento?
  motivo          String
  estado          EstadoCita       @default(PROGRAMADA)
  notas           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  paciente  Paciente   @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  consultas Consulta[]

  @@index([pacienteId])
  @@index([fecha])
  @@index([estado])
  @@map("citas")
}

enum EstadoCita {
  PROGRAMADA
  CONFIRMADA
  EN_CURSO
  COMPLETADA
  CANCELADA
  NO_ASISTIO
}

model Producto {
  id              String       @id @default(uuid())
  codigo          String       @unique
  nombre          String
  tipo            TipoProducto
  categoria       String?
  descripcion     String?
  marca           String?
  principioActivo String?
  precio          Decimal      @db.Decimal(10, 2)
  stock           Int          @default(0)
  stockMinimo     Int          @default(10)
  activo          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  itemsCobro      ItemCobro[]

  @@index([codigo])
  @@index([activo])
  @@index([tipo])
  @@map("productos")
}

enum TipoProducto {
  COSMECEUTICO
  DERMOCOSMETICO
  EQUIPO
  INSUMO
}

model Cobro {
  id                String      @id @default(uuid())
  pacienteId        String
  fecha             DateTime    @default(now())
  subtotal          Decimal     @default(0) @db.Decimal(10, 2)
  total             Decimal     @default(0) @db.Decimal(10, 2)
  estado            EstadoCobro @default(PENDIENTE)
  notas             String?
  fechaRecordatorio DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  paciente   Paciente    @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  items      ItemCobro[]
  pagos      Pago[]
  consulta   Consulta?   @relation(fields: [consultaId], references: [id])
  consultaId String?

  @@index([pacienteId])
  @@index([estado])
  @@index([fecha])
  @@index([fechaRecordatorio])
  @@map("cobros")
}

model ItemCobro {
  id             String        @id @default(uuid())
  cobroId        String
  tipo           TipoItemCobro
  productoId     String?
  nombre         String
  cantidad       Int
  precioUnitario Decimal       @db.Decimal(10, 2)
  subtotal       Decimal       @db.Decimal(10, 2)
  createdAt      DateTime      @default(now())

  cobro    Cobro     @relation(fields: [cobroId], references: [id], onDelete: Cascade)
  producto Producto? @relation(fields: [productoId], references: [id])

  @@index([cobroId])
  @@index([productoId])
  @@map("items_cobro")
}

enum TipoItemCobro {
  SERVICIO
  PRODUCTO
  PAQUETE
}

enum EstadoCobro {
  PENDIENTE
  PARCIAL
  PAGADO
  CANCELADO
}

model Pago {
  id         String     @id @default(uuid())
  cobroId    String
  fecha      DateTime   @default(now())
  monto      Decimal    @db.Decimal(10, 2)
  metodoPago MetodoPago
  referencia String?
  notas      String?
  createdAt  DateTime   @default(now())

  cobro Cobro @relation(fields: [cobroId], references: [id], onDelete: Cascade)

  @@index([cobroId])
  @@index([fecha])
  @@map("pagos")
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  OTRO
}

model Prescripcion {
  id         String   @id @default(uuid())
  pacienteId String
  usuarioId  String
  fecha      DateTime @default(now())
  nombre     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  paciente   Paciente           @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  usuario    Usuario            @relation(fields: [usuarioId], references: [id])
  items      ItemPrescripcion[]
  consulta   Consulta?          @relation(fields: [consultaId], references: [id])
  consultaId String?

  @@index([pacienteId])
  @@index([fecha])
  @@map("prescripciones")
}

model ItemPrescripcion {
  id             String                 @id @default(uuid())
  prescripcionId String
  nombre         String
  cantidad       Int
  aplicacion     String?
  estado         EstadoItemPrescripcion @default(INDICADO)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  prescripcion Prescripcion @relation(fields: [prescripcionId], references: [id], onDelete: Cascade)

  @@index([prescripcionId])
  @@index([estado])
  @@map("items_prescripcion")
}

enum EstadoItemPrescripcion {
  INDICADO
  ADQUIRIDO
  EN_USO
  COMPLETADO
}

model Documento {
  id         String        @id @default(uuid())
  pacienteId String
  nombre     String
  tipo       TipoDocumento
  url        String
  publicId   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  paciente Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@index([pacienteId])
  @@index([tipo])
  @@map("documentos")
}

enum TipoDocumento {
  FOTO
  DOCUMENTO
}

model ConfiguracionClinica {
  id        String  @id @default("singleton")
  nombre    String
  direccion String
  telefono  String
  email     String
  nit       String?
  ciudad    String?
  pais      String? @default("Bolivia")
  logo      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("configuracion_clinica")
}
